{
  "methods": {
    "WS_GGI": {
      "step_scale": 1.2e0,
      "d_step_multiplier": 1.0,
      "initialization": {
        "mode": "physical",
        "linear_init_a": [0.0, 0.0],
        "linear_init_b": [1.0, 0.0],
        "e_init_mode": "output_residual",
        "theta_init": 1e-6
      }
    },
    "RGLS": {
      "stability_projection": false,
      "stability_radius": 0.98,
      "na": 2,
      "nb": 2,
      "nf": 2,
      "nd": 1,
      "initialization": {
        "mode": "physical",
        "linear_init_a": [0.0, 0.0],
        "linear_init_b": [1.0, 0.0],
        "e_init_mode": "output_residual",
        "theta_init": 1e-6
      },
      "regularization": {
        "enabled": true,
        "lambda": 1e-8
      }
    },
    "WS_GNI": {
      "step_size": 0.9,
      "d_step_multiplier": 1.0,
      "hessian_regularization": 1e-8,
      "initialization": {
        "mode": "physical",
        "linear_init_a": [0.0, 0.0],
        "linear_init_b": [1.0, 0.0],
        "e_init_mode": "output_residual",
        "theta_init": 1e-6
      },
      "notes": "Newton-style update using Hessian H = Phi' * Phi."
    },
    "WS_GGHAM_1_dH": {
      "eta": 2e-1,
      "hessian_mode": "diag",
      "hessian_regularization": 1e2,
      "order": 1,
      "notes": "Placeholder for gradient-root GHAM first-order update."
    },
    "WS_GGHAM_2_I": {
      "eta":1.7e-4,
      "linear_operator": "identity",
      "order": 2,
      "notes": "Second-order gradient-root GHAM update for L = I."
    },
      "WS_GGHAM_2_dH": {
          "eta": 2e-1,
          "hessian_regularization": 1e2,
          "linear_operator": "diag_hessian",
          "order": 2,
          "notes": "Second-order gradient-root GHAM update for L = diag(H_J), implemented with the two-step procedure from equation 26."
      },
      "WS_LGHAM_1_TIK": {
          "eps_0": "automatic",
          "eta": 2e-1,
          "inverse_solver": "tikhonov",
          "tikhonov_lambda": 1e-1,
          "order": 1,
          "notes": "Loss-root GHAM update using first-order correction term."
      },
    "WS_LGHAM_3_TIK": {
      "eps_0": "automatic",
      "eta": 2e-1,
      "inverse_solver": "tikhonov",
      "tikhonov_lambda": 1e-1,
      "order": 3,
      "notes": "Loss-root GHAM update using correction terms up to third order."
