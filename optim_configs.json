{
  "methods": {
    "WS_GGI": {
      "step_scale": 1.5,
      "initialization": {
        "mode": "physical",
        "linear_init_a": [0.0, 0.0],
        "linear_init_b": [1.0, 0.0],
        "e_init_mode": "output_residual",
        "theta_init": 1e-6
      }
    },
    "RGLS": {
      "stability_projection": false,
      "stability_radius": 0.98,
      "na": 2,
      "nb": 2,
      "nf": 2,
      "nd": 1,
      "initialization": {
        "mode": "physical",
        "linear_init_a": [0.0, 0.0],
        "linear_init_b": [1.0, 0.0],
        "e_init_mode": "output_residual",
        "theta_init": 1e-6
      },
      "regularization": {
        "enabled": true,
        "lambda": 1e-8
      }
    },
    "WS_GNI": {
      "step_size": 0.9,
      "hessian_regularization": 1e-8,
      "initialization": {
        "mode": "physical",
        "linear_init_a": [0.0, 0.0],
        "linear_init_b": [1.0, 0.0],
        "e_init_mode": "output_residual",
        "theta_init": 1e-6
      },
      "notes": "Newton-style update using Hessian H = Phi' * Phi."
    },
    "WS_GGHAM_1_dH": {
      "eta": 1e0,
      "hessian_mode": "diag",
      "hessian_regularization": 1e3,
      "order": 1,
      "notes": "Placeholder for gradient-root GHAM first-order update."
    },
    "WS_GGHAM_2_I": {
      "eta": 6e-5,
      "linear_operator": "identity",
      "order": 2,
      "notes": "Second-order gradient-root GHAM update for L = I (equation 24 in the notes)."
    },
    "WS_LGHAM_1": {
      "epsilon0": 1e-4,
      "inverse_solver": "pinv",
      "order": 1,
      "notes": "Placeholder for loss-root GHAM first-order update."
    },
    "WS_LGHAM_2": {
      "epsilon0": 1e-4,
      "inverse_solver": "tikhonov",
      "tikhonov_lambda": 1e-3,
      "order": 2,
      "notes": "Placeholder for loss-root GHAM second-order update."
    },
    "WS_LGHAM_3": {
      "epsilon0": 1e-4,
      "inverse_solver": "pinv",
      "order": 3,
      "notes": "Placeholder for loss-root GHAM third-order update."
    }
  }
}
